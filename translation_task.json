{
  "_comment": "翻译工具 — 黑盒模式任务配置",
  "_description": "编辑此文件后运行 python run.py 即可执行翻译",
  "task": {
    "name": "游戏术语翻译",
    "input_file": "input/翻译测试表.xlsx",
    "output_file": "output/翻译输出.xlsx",
    "output_format": "wide",
    "source_lang": "中文"
  },
  "languages": {
    "target": [
      "英语",
      "德语",
      "法语",
      "日语",
      "韩语",
      "瑞典语",
      "挪威语",
