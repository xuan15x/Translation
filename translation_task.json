    "_comment": "从上方列表增删语言即可控制输出列"
  },
  "translation": {
    "mode": "multilingual",
    "enable_two_pass": true,
    "skip_review_if_local_hit": true
  },
  "concurrency": {
    "limit": 5,
    "_comment": "并发任务数，API 限频时降低此值"
  }
}