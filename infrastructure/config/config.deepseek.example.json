{
  "_comment": "AI 智能翻译工作台 - DeepSeek 完整配置示例（复制为 config.json 并修改）",
  "_version": "v3.0.1",
  "_description": "支持 DeepSeek 完整采样参数的配置文件",

  "// ========== 1. API 认证配置 ==========" : "",
  "api_key": "sk-your-deepseek-api-key-here",
  "base_url": "https://api.deepseek.com",
  "api_provider": "deepseek",

  "// ========== 2. 多 API 提供商配置 ==========" : "",
  "api_providers": {
    "deepseek": {
      "api_key": "sk-your-deepseek-api-key-here",
      "base_url": "https://api.deepseek.com"
    },
    "openai": {
      "api_key": "sk-your-openai-api-key-here",
      "base_url": "https://api.openai.com/v1"
    },
    "azure_openai": {
      "api_key": "your-azure-api-key",
      "base_url": "https://YOUR_RESOURCE.openai.azure.com/"
    }
  },

  "// ========== 3. 全局模型配置 ==========" : "",
  "model_name": "deepseek-chat",

  "// --- 3.1 采样参数（DeepSeek 完整支持） ---" : "",
  "temperature": 0.7,
  "_temperature_desc": "创造性参数 (0.0-2.0)：0.3 准确，0.7 平衡，1.0+ 创意",
  
  "top_p": 0.9,
  "_top_p_desc": "核采样参数 (0.0-1.0)：0.8 稳定，0.9 灵活，1.0 完全随机",
  
  "presence_penalty": 0.0,
  "_presence_penalty_desc": "存在惩罚 (-2.0~2.0)：正值鼓励新话题，负值重复已有话题",
  
  "frequency_penalty": 0.0,
  "_frequency_penalty_desc": "频率惩罚 (-2.0~2.0)：正值减少重复，负值增加重复",
  
  "stop": null,
  "_stop_desc": "停止序列列表，如 ['\\n\\n', 'END']，null 表示不使用",

  "// --- 3.2 高级参数 ---" : "",
  "max_tokens": 512,
  "_max_tokens_desc": "单次响应最大 token 数",
  
  "timeout": 60,
  "_timeout_desc": "请求超时时间（秒）",
  
  "max_retries": 3,
  "_max_retries_desc": "失败重试次数",
  
  "retry_streak_threshold": 3,
  "_retry_streak_threshold_desc": "连续失败触发降级的阈值",
  
  "base_retry_delay": 3.0,
  "_base_retry_delay_desc": "基础重试延迟（秒）",
  
  "context_window_size": null,
  "_context_window_size_desc": "上下文窗口大小（null=自动，DeepSeek Chat 支持 32K）",
  
  "enable_cache_control": true,
  "_enable_cache_control_desc": "是否启用缓存控制",
  
  "enable_stream": false,
  "_enable_stream_desc": "是否启用流式输出（true=实时显示，false=等待完成）",

  "// --- 3.3 自定义请求头（高级用户） ---" : "",
  "custom_headers": {},
  "_custom_headers_desc": "自定义 HTTP 请求头",

  "// --- 3.4 额外请求体参数（OpenAI 兼容） ---" : "",
  "extra_body": {},
  "_extra_body_desc": "额外的请求体参数，如 {'metadata': 'custom'}",

  "// ========== 4. 并发控制 ==========" : "",
  "initial_concurrency": 8,
  "_initial_concurrency_desc": "初始并发数，建议从 8 开始",
  
  "max_concurrency": 10,
  "_max_concurrency_desc": "最大并发数，根据 API 限制调整",
  
  "concurrency_cooldown_seconds": 5.0,
  "_concurrency_cooldown_seconds_desc": "并发冷却时间（秒）",

  "// ========== 5. 双阶段翻译参数 ==========" : "",
  "enable_two_pass": true,
  "_enable_two_pass_desc": "是否启用双阶段翻译（初译 + 校对）",
  
  "skip_review_if_local_hit": true,
  "_skip_review_if_local_hit_desc": "术语库本地命中时跳过校对",

  "// --- 5.1 初译阶段（Draft）专用配置 ---" : "",
  "draft_model_name": null,
  "_draft_model_name_desc": "初译模型（null=使用全局 model_name）",
  
  "draft_temperature": null,
  "_draft_temperature_desc": "初译温度（null=使用全局 temperature，建议 0.3-0.4）",
  
  "draft_top_p": null,
  "_draft_top_p_desc": "初译 top_p（null=使用全局 top_p，建议 0.8）",
  
  "draft_presence_penalty": null,
  "_draft_presence_penalty_desc": "初译存在惩罚（null=使用全局值）",
  
  "draft_frequency_penalty": null,
  "_draft_frequency_penalty_desc": "初译频率惩罚（null=使用全局值）",
  
  "draft_timeout": null,
  "_draft_timeout_desc": "初译超时（null=使用全局 timeout）",
  
  "draft_max_tokens": 512,
  "_draft_max_tokens_desc": "初译最大 token 数",

  "// --- 5.2 校对阶段（Review）专用配置 ---" : "",
  "review_model_name": null,
  "_review_model_name_desc": "校对模型（null=使用全局 model_name）",
  
  "review_temperature": null,
  "_review_temperature_desc": "校对温度（null=使用全局 temperature，建议 0.5-0.7）",
  
  "review_top_p": null,
  "_review_top_p_desc": "校对 top_p（null=使用全局 top_p，建议 0.9）",
  
  "review_presence_penalty": null,
  "_review_presence_penalty_desc": "校对存在惩罚（null=使用全局值）",
  
  "review_frequency_penalty": null,
  "_review_frequency_penalty_desc": "校对频率惩罚（null=使用全局值）",
  
  "review_timeout": null,
  "_review_timeout_desc": "校对超时（null=使用全局 timeout）",
  
  "review_max_tokens": 512,
  "_review_max_tokens_desc": "校对最大 token 数",

  "// ========== 6. 翻译流程配置 ==========" : "",
  "batch_size": 1000,
  "_batch_size_desc": "批量翻译大小",
  
  "gc_interval": 2,
  "_gc_interval_desc": "垃圾回收间隔（每 N 个任务执行一次 GC）",

  "// ========== 7. 术语库配置 ==========" : "",
  "similarity_low": 60,
  "_similarity_low_desc": "模糊匹配阈值（0-100）",
  
  "exact_match_score": 100,
  "_exact_match_score_desc": "精确匹配置信度",
  
  "multiprocess_threshold": 1000,
  "_multiprocess_threshold_desc": "多进程处理阈值（术语库>1000 条时使用多进程）",

  "// ========== 8. 数据库与缓存 ==========" : "",
  "pool_size": 5,
  "_pool_size_desc": "数据库连接池大小",
  
  "cache_capacity": 2000,
  "_cache_capacity_desc": "LRU 缓存容量",
  
  "cache_ttl_seconds": 3600,
  "_cache_ttl_seconds_desc": "缓存生存时间（秒，0=永不过期）",

  "// ========== 9. 日志系统 ==========" : "",
  "log_level": "INFO",
  "_log_level_desc": "日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL",
  
  "log_granularity": "normal",
  "_log_granularity_desc": "日志粒度：minimal/basic/normal/detailed/verbose",
  
  "log_max_lines": 1000,
  "_log_max_lines_desc": "GUI 日志最大行数",

  "// ========== 10. GUI 界面 ==========" : "",
  "gui_window_title": "AI 智能翻译工作台 v3.0",
  "gui_window_width": 950,
  "gui_window_height": 800,

  "// ========== 11. 提示词配置 ==========" : "",
  "draft_prompt": "Role: Professional Translator.\nTask: Translate 'Src' to {target_lang}.\nConstraints:\n1. Output JSON ONLY: {\"Trans\": \"string\"}.\n2. Strictly follow provided TM.\n3. Accurate and direct.",

  "review_prompt": "Role: Senior Language Editor.\nTask: Polish 'Draft' into native {target_lang}.\nConstraints:\n1. Output JSON ONLY: {\"Trans\": \"string\", \"Reason\": \"string\"}.\n2. 'Reason': Max 10 chars. If no change, Reason=\"\".\n3. Focus on flow and tone.",

  "// ========== 12. 禁止事项配置 ==========" : "",
  "prohibition_config": {
    "global_prohibitions": [
      "禁止输出原文或保留未翻译的内容",
      "禁止添加解释性文字或注释",
      "禁止改变原文的语气和情感色彩"
    ],
    "match3_prohibitions": [
      "禁止使用超过 4 个字的道具名称（UI 限制）",
      "禁止使用生僻字或难以识别的汉字"
    ]
  },

  "// ========== 13. 语言配置 ==========" : "",
  "target_languages": [
    "英语", "德语", "法语", "日语", "韩语",
    "意大利语", "西班牙语", "葡萄牙语", "泰语", "越南语",
    "印尼语", "马来语", "俄语", "波兰语", "土耳其语", "阿拉伯语"
  ],

  "favorite_languages": ["英语", "日语", "韩语"],

  "default_source_lang": "中文",
  
  "supported_source_langs": ["中文", "英语", "日语", "韩语", "法语", "德语", "西班牙语", "意大利语", "葡萄牙语", "俄语"],

  "// ========== 14. 游戏翻译方向 ==========" : "",
  "enabled_translation_types": [
    "match3_item",
    "match3_skill",
    "match3_level",
    "match3_dialogue",
    "match3_ui",
    "dialogue",
    "ui",
    "scene",
    "tutorial",
    "achievement",
    "custom"
  ],

  "// ========== 15. 版本控制与备份 ==========" : "",
  "enable_version_control": false,
  "enable_auto_backup": false,
  "backup_dir": ".terminology_backups",
  "backup_strategy": "daily",

  "// ========== 16. 性能监控 ==========" : "",
  "enable_performance_monitor": false,
  "perf_sample_interval": 1.0,
  "perf_history_size": 300
}
