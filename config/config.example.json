{
  "_comment": "AI 智能翻译工作台 - JSON 配置文件（复制为 config.json 并修改）",
  "_version": "v3.0.0",
  
  // ============================================================
  // 【API 配置】- 必须设置
  // ============================================================
  // 直接设置模型名称，自动识别提供商
  "model_name": "deepseek-chat",   // ⚠️ 全局默认模型名称
  
  // API 密钥配置（支持多提供商）
  "api_keys": {
    "deepseek": {
      "api_key": "aa",  // ⚠️ DeepSeek API 密钥
      "base_url": "https://api.deepseek.com"
    },
    "openai": {
      "api_key": "sk-your-openai-api-key-here",    // ⚠️ OpenAI API 密钥
      "base_url": "https://api.openai.com/v1"
    },
    "azure_openai": {
      "api_key": "your-azure-api-key-here",        // ⚠️ Azure API 密钥
      "base_url": "https://YOUR_RESOURCE.openai.azure.com/"
    },
    "custom": {
      "api_key": "your-custom-api-key-here",       // ⚠️ 自定义 API 密钥
      "base_url": "https://your-api-server.com/v1"
    }
  },
  "temperature": 0.3,    // 创造性 (0.0-2.0)：越低越准确，越高越有创意（推荐 0.3-0.5）
  "top_p": 0.8,          // 核采样参数 (0.0-1.0)：控制词汇多样性（推荐 0.8-0.9）
  "timeout": 60,         // 请求超时时间（秒）（推荐 30-120 秒）
  "max_retries": 3,      // 最大重试次数（推荐 2-5 次）
  "retry_streak_threshold": 3,   // 连续失败阈值（用于自适应并发控制）
  "base_retry_delay": 3.0,       // 基础重试延迟（秒）
  
  // ============================================================
  // 【并发控制】- 影响翻译速度和稳定性
  // ============================================================
  "initial_concurrency": 8,         // 初始并发数：建议从 8 开始
  "max_concurrency": 10,            // 最大并发数：根据 API 限制调整
  "concurrency_cooldown_seconds": 5.0,  // 并发冷却时间（秒）
  
  // ============================================================
  // 【双阶段翻译参数】- 为初译和校对设置不同的模型参数
  // ============================================================
  // 如果设置为 null，则使用全局 model_name 和其他参数
  // 初译阶段（Draft）专用配置
  "draft_model_name": null,     // 初译模型（null=使用全局 model_name）
  "draft_temperature": null,    // 初译温度（null=使用全局 temperature）
  "draft_top_p": null,          // 初译 top_p（null=使用全局 top_p）
  "draft_timeout": null,        // 初译超时（null=使用全局 timeout）
  "draft_max_tokens": 512,      // 初译最大 token 数
  
  // 校对阶段（Review）专用配置
  "review_model_name": null,    // 校对模型（null=使用全局 model_name）
  "review_temperature": null,   // 校对温度（null=使用全局 temperature）
  "review_top_p": null,         // 校对 top_p（null=使用全局 top_p）
  "review_timeout": null,       // 校对超时（null=使用全局 timeout）
  "review_max_tokens": 512,     // 校对最大 token 数
  
  // ============================================================
  // 【重试机制】- 提高稳定性
  // ============================================================
  "retry_streak_threshold": 3,   // 连续失败阈值
  "base_retry_delay": 3.0,       // 基础重试延迟（秒）
  "max_retries": 3,              // 最大重试次数
  "timeout": 60,                 // 请求超时时间（秒）
  
  // ============================================================
  // 【翻译流程】- 控制翻译行为
  // ============================================================
  "translation_mode": "full",         // 翻译模式：draft_only（仅初译）/ review_only（仅校对）/ full（完整双阶段）
  "enable_two_pass": true,           // 启用两阶段翻译（初译 + 校对）
  "skip_review_if_local_hit": true,  // 术语库本地命中时跳过校对
  "batch_size": 1000,                // 批量翻译大小
  "gc_interval": 2,                  // 垃圾回收间隔

  // ============================================================
  // 【提示词模板配置】- 自定义提示词结构（高级）
  // ============================================================
  "prompt_templates": {
    "draft": {
      "role": "Professional Translator",
      "task": "Translate 'Src' to {target_lang}",
      "constraints": [
        "Output JSON ONLY: {\"Trans\": \"string\"}",
        "Strictly follow provided TM",
        "Accurate and direct"
      ]
    },
    "review": {
      "role": "Senior Language Editor",
      "task": "Polish 'Draft' into native {target_lang}",
      "constraints": [
        "Output JSON ONLY: {\"Trans\": \"string\", \"Reason\": \"string\"}",
        "'Reason': Max 10 chars. If no change, Reason=\"\"",
        "Focus on flow and tone"
      ]
    }
  },

  // ============================================================
  // 【术语库】- 模糊匹配配置
  // ============================================================
  "similarity_low": 60,              // 最低相似度阈值（0-100）
  "exact_match_score": 100,          // 完全匹配分数
  "multiprocess_threshold": 1000,    // 多进程处理阈值
  
  // ============================================================
  // 【数据库与缓存】- 性能优化
  // ============================================================
  "pool_size": 5,              // 数据库连接池大小
  "cache_capacity": 2000,      // LRU 缓存容量
  "cache_ttl_seconds": 3600,   // 缓存生存时间（秒）
  // ============================================================
  // 【日志系统】- 调试与监控
  // ============================================================
  "log_level": "INFO",         // 日志级别：DEBUG/INFO/WARNING/ERROR
  "log_granularity": "normal", // 日志粒度：minimal/basic/normal/detailed/verbose
  "log_max_lines": 1000,       // GUI 日志最大行数
  
  // ============================================================
  // 【GUI 界面】- 窗口配置
  // ============================================================
  "gui_window_title": "AI 智能翻译工作台 v3.0",  // 窗口标题
  "gui_window_width": 950,     // 窗口宽度
  "gui_window_height": 800,    // 窗口高度
  
  // ============================================================
  // 【提示词配置】- 可自定义翻译风格
  // ============================================================
  "draft_prompt": "Role: Professional Translator.\nTask: Translate 'Src' to {target_lang}.\nConstraints:\n1. Output JSON ONLY: \"Trans\": \"string\".\n2. Strictly follow provided TM.\n3. Accurate and direct.",
  
  "review_prompt": "Role: Senior Language Editor.\nTask: Polish 'Draft' into native {target_lang}.\nConstraints:\n1. Output JSON ONLY: \"Trans\": \"string\", \"Reason\": \"string\".\n2. 'Reason': Max 10 chars. If no change, Reason=\"\".\n3. Focus on flow and tone.",
  
  // ============================================================
  // 【禁止事项配置】- 自动注入到提示词中的禁止规则
  // ============================================================
  // 说明：这些禁止事项会自动注入到每个翻译请求中，确保翻译质量
  // 可以按翻译类型配置不同的禁止规则
  "prohibition_config": {
    // 通用禁止事项（适用于所有翻译类型）
    "global_prohibitions": [
      "禁止输出原文或保留未翻译的内容",
      "禁止添加解释性文字或注释",
      "禁止改变原文的语气和情感色彩",
      "禁止使用过于书面化或学术化的表达",
      "禁止创造原文没有的新内容",
      "禁止遗漏原文的关键信息",
      "禁止使用敏感或不适当的词汇",
      "禁止混用不同语言的表达方式"
    ],
    
    // 三消游戏专项禁止事项
    "match3_prohibitions": [
      "禁止使用超过 4 个字的道具名称（UI 限制）",
      "禁止使用生僻字或难以识别的汉字",
      "禁止使用可能引起文化误解的颜色/形状描述",
      "禁止使用过于复杂或晦涩的比喻",
      "禁止使用成人向或暴力倾向的描述"
    ],
    
    // UI 界面专项禁止事项
    "ui_prohibitions": [
      "禁止使用超过按钮容量的长文本",
      "禁止使用需要思考才能理解的表达",
      "禁止使用非标准的 UI 术语（如用'设定'代替'设置'）",
      "禁止使用可能产生歧义的简短表达"
    ],
    
    // 对话剧情专项禁止事项
    "dialogue_prohibitions": [
      "禁止使用不符合角色性格的语言风格",
      "禁止过度本地化导致失去原作韵味",
      "禁止使用与时代背景不符的流行语",
      "禁止改变对话的情感倾向（严肃→玩笑等）"
    ]
  },
  
  // 各翻译类型对应的禁止事项映射（一般不需要修改）
  "prohibition_type_map": {
    "match3_item": ["global", "match3"],
    "match3_skill": ["global", "match3"],
    "match3_level": ["global", "match3"],
    "match3_dialogue": ["global", "match3", "dialogue"],
    "match3_ui": ["global", "match3", "ui"],
    "dialogue": ["global", "dialogue"],
    "ui": ["global", "ui"],
    "scene": ["global"],
    "tutorial": ["global"],
    "achievement": ["global"],
    "custom": ["global"]
  },
  
  // ============================================================
  // 【语言配置】- 支持的语言（按游戏市场 T1/T2/T3 分级）
  // ============================================================
  "target_languages": [
    // T1 - 核心市场
    "英语", "德语", "法语", "日语", "韩语",
    "瑞典语", "挪威语", "丹麦语", "芬兰语",
    // T2 - 潜力市场
    "意大利语", "西班牙语", "葡萄牙语", "泰语", "越南语",
    "印尼语", "马来语", "俄语", "波兰语", "土耳其语", "阿拉伯语",
    // T3 - 新兴市场
    "印地语", "乌尔都语", "孟加拉语", "菲律宾语", "缅甸语",
    "柬埔寨语", "老挝语", "波斯语", "希伯来语", "斯瓦希里语",
    "豪萨语", "哈萨克语", "乌兹别克语"
  ],
  
  // 常用语言（上次翻译任务使用的语言，自动显示在"⭐ 常用语言"分页）
  "favorite_languages": ["英语", "日语", "韩语"],
  
  "default_source_lang": "中文",  // 默认源语言
  "supported_source_langs": ["中文", "英语", "日语", "韩语", "法语", "德语", "西班牙语", "意大利语", "葡萄牙语", "俄语"],
  
  // ============================================================
  // 【游戏翻译方向】- 用户可自定义启用的方向
  // ============================================================
  // 说明：可以在这里配置启用哪些翻译方向，未启用的方向不会在 GUI 中显示
  "enabled_translation_types": [
    "match3_item",      // 三消 - 道具元素
    "match3_skill",     // 三消 - 技能特效
    "match3_level",     // 三消 - 关卡目标
    "match3_dialogue",  // 三消 - 角色对话
    "match3_ui",        // 三消 - UI 界面
    "dialogue",         // 通用 - 对话剧情
    "ui",               // 通用 - UI 界面
    "scene",            // 通用 - 场景描述
    "tutorial",         // 通用 - 教程提示
    "achievement",      // 通用 - 成就称号
    "custom"            // 自定义
  ],
  
  // ============================================================
  // 【版本控制与备份】- 术语库管理
  // ============================================================
  "enable_version_control": false,   // 启用术语库版本控制
  "enable_auto_backup": false,       // 启用自动备份
  "backup_dir": ".terminology_backups",  // 备份目录
  "backup_strategy": "daily",        // 备份策略：daily/weekly/manual
  
  // ============================================================
  // 【性能监控】- 高级功能（可在 GUI 中开启）
  // ============================================================
  "enable_performance_monitor": false,  // 是否默认启用性能监控（false=关闭，true=开启）
  "perf_sample_interval": 1.0,         // 采样间隔（秒）
  "perf_history_size": 300             // 历史记录大小
}
