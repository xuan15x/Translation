{
  "_comment": "AI 智能翻译工作台 - JSON 配置文件（复制为 config.json 并修改）",
  "_version": "v3.0.0",
  
  // ============================================================
  // 【API 配置】- 必须设置
  // ============================================================
  // 默认 API 提供商（从下方 api_providers 中选择）
  "api_provider": "deepseek",
  
  // 多 API 提供商配置（未配置 api_key 的不会显示）
  "api_providers": {
    "deepseek": {
      "api_key": "aa",  // ⚠️ DeepSeek API 密钥
      "base_url": "https://api.deepseek.com",
      "model_name": "deepseek-chat",
      "models": [  // 支持的模型列表
        "deepseek-chat",
        "deepseek-coder"
      ]
    },
    "openai": {
      "api_key": "sk-your-openai-api-key-here",    // ⚠️ OpenAI API 密钥
      "base_url": "https://api.openai.com/v1",
      "model_name": "gpt-3.5-turbo",
      "models": [  // 支持的模型列表
        "gpt-3.5-turbo",
        "gpt-4",
        "gpt-4-turbo"
      ]
    },
    "azure_openai": {
      "api_key": "your-azure-api-key-here",        // ⚠️ Azure API 密钥
      "base_url": "https://YOUR_RESOURCE.openai.azure.com/",
      "model_name": "gpt-35-turbo",                // Azure 部署名称
      "models": [  // Azure 部署的模型
        "gpt-35-turbo",
        "gpt-4"
      ]
    },
    "custom": {
      "api_key": "your-custom-api-key-here",       // ⚠️ 自定义 API 密钥
      "base_url": "https://your-api-server.com/v1",
      "model_name": "your-model-name",
      "models": [  // 自定义模型
        "your-model-name"
      ]
    }
  },
  
  // ============================================================
  // 【模型参数】- 影响翻译质量
  // ============================================================
  "model_name": "deepseek-chat",   // ⚠️ 全局默认模型名称
  "temperature": 0.3,    // 创造性 (0.0-2.0)：越低越准确，越高越有创意（推荐 0.3-0.5）
  "top_p": 0.8,          // 核采样参数 (0.0-1.0)：控制词汇多样性（推荐 0.8-0.9）
  "timeout": 60,         // 请求超时时间（秒）（推荐 30-120 秒）
  "max_retries": 3,      // 最大重试次数（推荐 2-5 次）
  "retry_streak_threshold": 3,   // 连续失败阈值（用于自适应并发控制）
  "base_retry_delay": 3.0,       // 基础重试延迟（秒）
  
  // ============================================================
  // 【双阶段翻译参数】- 为初译和校对设置不同的模型参数
  // ============================================================
  // 初译阶段（Draft）专用配置
  "draft_model_name": null,     // 初译模型，null 表示使用全局 model_name
  "draft_temperature": null,    // 初译温度，null 表示使用全局 temperature（推荐 0.3-0.4）
  "draft_top_p": null,          // 初译 top_p，null 表示使用全局 top_p（推荐 0.8）
  "draft_timeout": null,        // 初译超时，null 表示使用全局 timeout
  "draft_max_tokens": 512,      // 初译最大 token 数（推荐 512-1024）
  
  // 校对阶段（Review）专用配置
  "review_model_name": null,    // 校对模型，null 表示使用全局 model_name
  "review_temperature": null,   // 校对温度，null 表示使用全局 temperature（推荐 0.5-0.7）
  "review_top_p": null,         // 校对 top_p，null 表示使用全局 top_p（推荐 0.9）
  "review_timeout": null,       // 校对超时，null 表示使用全局 timeout
  "review_max_tokens": 512,     // 校对最大 token 数（推荐 512-1024）
  
  // ============================================================
  // 【并发控制】- 影响翻译速度和稳定性
  // ============================================================
  "initial_concurrency": 8,         // 初始并发数：建议从 8 开始
  "max_concurrency": 10,            // 最大并发数：根据 API 限制调整
  "concurrency_cooldown_seconds": 5.0,  // 并发冷却时间（秒）
  
  // ============================================================
  // 【重试机制】- 提高稳定性
  // ============================================================
  "retry_streak_threshold": 3,   // 连续失败阈值
  "base_retry_delay": 3.0,       // 基础重试延迟（秒）
  "max_retries": 3,              // 最大重试次数
  "timeout": 60,                 // 请求超时时间（秒）
  
  // ============================================================
  // 【翻译流程】- 控制翻译行为
  // ============================================================
  "enable_two_pass": true,           // 启用两阶段翻译（初译 + 校对）
  "skip_review_if_local_hit": true,  // 术语库本地命中时跳过校对
  "batch_size": 1000,                // 批量翻译大小
  "gc_interval": 2,                  // 垃圾回收间隔
  
  // ============================================================
  // 【术语库】- 模糊匹配配置
  // ============================================================
  "similarity_low": 60,              // 最低相似度阈值（0-100）
  "exact_match_score": 100,          // 完全匹配分数
  "multiprocess_threshold": 1000,    // 多进程处理阈值
  
  // ============================================================
  // 【数据库与缓存】- 性能优化
  // ============================================================
  "pool_size": 5,              // 数据库连接池大小
  "cache_capacity": 2000,      // LRU 缓存容量
  "cache_ttl_seconds": 3600,   // 缓存生存时间（秒）
  
  // Redis 缓存配置（可选，用于高并发场景）
  "redis_cache": {
    "enabled": false,          // 是否启用 Redis 缓存
    "host": "localhost",       // Redis 服务器地址
    "port": 6379,              // Redis 端口
    "password": null,          // Redis 密码（可选）
    "db": 0,                   // Redis 数据库编号
    "key_prefix": "translation:terminology:",  // 键前缀
    "default_ttl": 3600,       // 默认过期时间（秒）
    "exact_match_ttl": 7200,   // 精确匹配过期时间（秒）
    "fuzzy_match_ttl": 1800,   // 模糊匹配过期时间（秒）
    "max_connections": 50      // 最大连接数
  },
  // ============================================================
  // 【日志系统】- 调试与监控
  // ============================================================
  "log_level": "INFO",         // 日志级别：DEBUG/INFO/WARNING/ERROR
  "log_granularity": "normal", // 日志粒度：minimal/basic/normal/detailed/verbose
  "log_max_lines": 1000,       // GUI 日志最大行数
  
  // ============================================================
  // 【GUI 界面】- 窗口配置
  // ============================================================
  "gui_window_title": "AI 智能翻译工作台 v3.0",  // 窗口标题
  "gui_window_width": 950,     // 窗口宽度
  "gui_window_height": 800,    // 窗口高度
  
  // ============================================================
  // 【提示词配置】- 可自定义翻译风格
  // ============================================================
  "draft_prompt": "Role: Professional Translator.\nTask: Translate 'Src' to {target_lang}.\nConstraints:\n1. Output JSON ONLY: \"Trans\": \"string\".\n2. Strictly follow provided TM.\n3. Accurate and direct.",
  
  "review_prompt": "Role: Senior Language Editor.\nTask: Polish 'Draft' into native {target_lang}.\nConstraints:\n1. Output JSON ONLY: \"Trans\": \"string\", \"Reason\": \"string\".\n2. 'Reason': Max 10 chars. If no change, Reason=\"\".\n3. Focus on flow and tone.",
  
  // ============================================================
  // 【语言配置】- 支持的语言
  // ============================================================
  "target_languages": [
    "英语", "日语", "韩语", "法语", "德语", 
    "西班牙语", "俄语", "葡萄牙语", "意大利语", 
    "阿拉伯语", "泰语", "越南语"
  ],
  
  "default_source_lang": "中文",  // 默认源语言
  "supported_source_langs": ["中文", "英语", "日语", "韩语", "法语", "德语"],
  
  // ============================================================
  // 【版本控制与备份】- 术语库管理
  // ============================================================
  "enable_version_control": false,   // 启用术语库版本控制
  "enable_auto_backup": false,       // 启用自动备份
  "backup_dir": ".terminology_backups",  // 备份目录
  "backup_strategy": "daily",        // 备份策略：daily/weekly/manual
  
  // ============================================================
  // 【性能监控】- 高级功能
  // ============================================================
  "enable_performance_monitor": false,  // 启用性能监控
  "perf_sample_interval": 1.0,         // 采样间隔（秒）
  "perf_history_size": 300             // 历史记录大小
}
